{
  "name": "aegis-security-monitor",
  "version": "2.0.0",
  "description": "🛡️ AI Agent Security Monitor - npm一键安装版本",
  "main": "index.js",
  "bin": {
    "aegis": "./bin/aegis.js"
  },
  "scripts": {
    "aegis:setup": "node scripts/setup.js",
    "aegis:start": "node scripts/start.js",
    "aegis:stop": "node scripts/stop.js",
    "aegis:monitor": "node scripts/monitor.js",
    "aegis:test": "node scripts/test.js",
    "aegis:status": "node scripts/status.js",
    "setup": "npm run aegis:setup",
    "start": "node real-time-monitor.js",
    "start:debug": "node src/port-manager.js diagnose && node real-time-monitor.js",
    "stop": "npm run aegis:stop",
    "monitor": "npm run aegis:monitor",
    "test": "npm run aegis:test",
    "status": "npm run aegis:status",
    "postinstall": "echo '🎉 Aegis 已安装！执行: npm run setup && npm start'",
    "prestart": "node scripts/check-setup.js"
  },
  "keywords": [
    "security",
    "ai",
    "claude",
    "hook",
    "monitoring",
    "npm",
    "one-click"
  ],
  "author": "Aegis Security Team",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "scripts/",
    "bin/",
    "templates/",
    "index.js",
    "README.md"
  ],
  "dependencies": {
    "@types/blessed": "^0.1.27",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/shell-quote": "^1.7.5",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "express-test": "^0.1.2",
    "js-yaml": "^4.1.1",
    "shell-quote": "^1.8.3",
    "typescript": "^6.0.3",
    "ws": "^8.20.0"
  },
  "preferGlobal": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/aegis-security/aegis-monitor.git"
  },
  "homepage": "https://aegis-security.github.io",
  "bugs": {
    "url": "https://github.com/aegis-security/aegis-monitor/issues"
  }
}
