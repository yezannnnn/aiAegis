{
  "name": "ai-aegis",
  "version": "0.4.2",
  "description": "AI Agent Security Monitor — intercept and approve dangerous commands in real-time",
  "main": "bin/aegis.js",
  "bin": {
    "aegis": "./bin/aegis.js"
  },
  "scripts": {
    "build": "node bin/aegis.js build",
    "start": "node bin/aegis.js start",
    "postinstall": "node bin/postinstall.js",
    "prepublishOnly": "npm run build",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0"
  },
  "files": [
    "bin/",
    "backend/dist/",
    "backend/package.json",
    "frontend/dist/",
    "hooks/claude-code/universal-hook-v2.js",
    "hooks/claude-code/post-tool-use-handler.js",
    "hooks/hermes/plugin.py",
    "hooks/hermes/README.md",
    "README.md"
  ],
  "keywords": [
    "ai",
    "security",
    "monitor",
    "agent",
    "cli",
    "claude",
    "nestjs",
    "hook",
    "approval"
  ],
  "author": "yezannnnn",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "cross-spawn": "^7.0.3",
    "fs-extra": "^11.0.0",
    "inquirer": "^8.2.4",
    "ora": "^5.4.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yezannnnn/aiAegis.git"
  },
  "bugs": {
    "url": "https://github.com/yezannnnn/aiAegis/issues"
  },
  "homepage": "https://github.com/yezannnnn/aiAegis#readme",
  "devDependencies": {
    "conventional-changelog-cli": "^4.1.0"
  }
}
