{
  "name": "aegis/recommended",
  "version": "1.0.0",
  "rules": [
    {
      "pattern": "\\brm\\s+(-[^\\s]*\\s+)*(/|/\\*)(\\s|$)",
      "description": "recursive delete of root filesystem",
      "category": "file-system",
      "severity": "block"
    },
    {
      "pattern": "\\brm\\s+(-[^\\s]*\\s+)*(/home|/root|/etc|/usr|/var|/bin|/sbin|/boot|/lib)(\\s|$)",
      "description": "recursive delete of system directory",
      "category": "file-system",
      "severity": "block"
    },
    {
      "pattern": "\\brm\\s+(-[^\\s]*\\s+)*(~|\\$HOME)(/?|/\\*)?(\\s|$)",
      "description": "recursive delete of home directory",
      "category": "file-system",
      "severity": "block"
    },
    {
      "pattern": "\\bmkfs(\\.[a-z0-9]+)?\\b",
      "description": "format filesystem",
      "category": "file-system",
      "severity": "block"
    },
    {
      "pattern": "\\bdd\\b[^\\n]*\\bof=/dev/(sd|nvme|hd|mmcblk|vd|xvd)[a-z0-9]*",
      "description": "dd to raw block device",
      "category": "file-system",
      "severity": "block"
    },
    {
      "pattern": ":\\(\\)\\s*\\{\\s*:\\s*\\|\\s*:\\s*&\\s*\\}\\s*;\\s*:",
      "description": "fork bomb",
      "category": "process",
      "severity": "block"
    },
    {
      "pattern": "\\bkill\\s+(-[^\\s]+\\s+)*-1\\b",
      "description": "kill all processes",
      "category": "process",
      "severity": "block"
    },
    {
      "pattern": "(shutdown|reboot|halt|poweroff)\\b",
      "description": "system shutdown/reboot",
      "category": "system",
      "severity": "block"
    },
    {
      "pattern": "systemctl\\s+(poweroff|reboot|halt|kexec)\\b",
      "description": "systemctl poweroff/reboot",
      "category": "system",
      "severity": "block"
    },
    {
      "pattern": "\\brm\\s+-[^\\s]*r",
      "description": "recursive delete",
      "category": "file-system",
      "severity": "error"
    },
    {
      "pattern": "\\bchmod\\s+(-[^\\s]*\\s+)*(777|666|o\\+[rwx]*w|a\\+[rwx]*w)\\b",
      "description": "world-writable permissions",
      "category": "file-system",
      "severity": "error"
    },
    {
      "pattern": "\\bchown\\s+(-[^\\s]*)?R\\s+root",
      "description": "recursive chown to root",
      "category": "file-system",
      "severity": "error"
    },
    {
      "pattern": "\\bfind\\b.*-exec\\s+(/\\S*/)?rm\\b",
      "description": "find -exec rm",
      "category": "file-system",
      "severity": "error"
    },
    {
      "pattern": "\\bfind\\b.*-delete\\b",
      "description": "find -delete",
      "category": "file-system",
      "severity": "error"
    },
    {
      "pattern": "\\b(cp|mv|install)\\b.*\\s/etc/",
      "description": "copy/move file into /etc",
      "category": "file-system",
      "severity": "error"
    },
    {
      "pattern": "\\bsed\\s+-[^\\s]*i.*\\s/etc/",
      "description": "in-place edit of system config",
      "category": "file-system",
      "severity": "error"
    },
    {
      "pattern": "\\b(bash|sh|zsh|ksh)\\s+-[^\\s]*c(\\s+|$)",
      "description": "shell command via -c flag",
      "category": "shell",
      "severity": "error"
    },
    {
      "pattern": "\\b(python[23]?|perl|ruby|node)\\s+-[ec]\\s+",
      "description": "script execution via -e/-c",
      "category": "shell",
      "severity": "error"
    },
    {
      "pattern": "\\b(python[23]?|perl|ruby|node)\\s+<<",
      "description": "script execution via heredoc",
      "category": "shell",
      "severity": "error"
    },
    {
      "pattern": "\\b(curl|wget)\\b.*\\|\\s*(ba)?sh\\b",
      "description": "pipe remote content to shell",
      "category": "shell",
      "severity": "error"
    },
    {
      "pattern": "\\bchmod\\s+\\+x\\b.*[;&|]+\\s*\\./",
      "description": "chmod +x then immediate execution",
      "category": "shell",
      "severity": "error"
    },
    {
      "pattern": "\\bgit\\s+reset\\s+--hard\\b",
      "description": "git reset --hard",
      "category": "git",
      "severity": "error"
    },
    {
      "pattern": "\\bgit\\s+push\\b.*(--force|-f)\\b",
      "description": "git force push",
      "category": "git",
      "severity": "error"
    },
    {
      "pattern": "\\bgit\\s+clean\\s+-[^\\s]*f",
      "description": "git clean force",
      "category": "git",
      "severity": "error"
    },
    {
      "pattern": "\\bgit\\s+branch\\s+-D\\b",
      "description": "git branch force delete",
      "category": "git",
      "severity": "error"
    },
    {
      "pattern": "\\bDROP\\s+(TABLE|DATABASE)\\b",
      "description": "SQL DROP",
      "category": "database",
      "severity": "error"
    },
    {
      "pattern": "\\bDELETE\\s+FROM\\b(?!.*\\bWHERE\\b)",
      "description": "SQL DELETE without WHERE",
      "category": "database",
      "severity": "error"
    },
    {
      "pattern": "\\bTRUNCATE\\s+(TABLE)?\\s*\\w",
      "description": "SQL TRUNCATE",
      "category": "database",
      "severity": "error"
    },
    {
      "pattern": "\\bkill\\s+-9\\b",
      "description": "force kill process",
      "category": "process",
      "severity": "error"
    },
    {
      "pattern": "\\b(pkill|killall)\\b",
      "description": "kill process by name",
      "category": "process",
      "severity": "error"
    },
    {
      "pattern": "\\bsystemctl\\s+(-[^\\s]+\\s+)*(stop|restart|disable|mask)\\b",
      "description": "stop/restart system service",
      "category": "system",
      "severity": "error"
    },
    {
      "pattern": ">\\s*/etc/",
      "description": "overwrite system config",
      "category": "file-system",
      "severity": "error"
    },
    {
      "pattern": "\\btee\\b.*\\.env",
      "description": "write to .env file",
      "category": "file-system",
      "severity": "error"
    },
    {
      "pattern": "\\bdocker\\s+(rm|container\\s+rm)\\s+-f\\b",
      "description": "docker force remove container",
      "category": "docker",
      "severity": "error"
    },
    {
      "pattern": "\\bdocker\\s+system\\s+prune\\b",
      "description": "docker system prune",
      "category": "docker",
      "severity": "error"
    },
    {
      "pattern": "\\bdocker-compose\\s+down\\s+-v\\b",
      "description": "docker-compose down with volumes",
      "category": "docker",
      "severity": "error"
    },
    {
      "pattern": "\\bnc\\b.*-[^\\s]*[el].*/bin/(ba)?sh",
      "description": "netcat reverse shell",
      "category": "network",
      "severity": "error"
    },
    {
      "pattern": "\\bnpm\\s+unpublish\\b",
      "description": "npm unpublish",
      "category": "package",
      "severity": "error"
    },
    {
      "pattern": "\\bnpm\\s+install\\s+-g\\b",
      "description": "npm global install",
      "category": "package",
      "severity": "warn"
    },
    {
      "pattern": "\\bpip\\s+install\\b(?!.*--user)",
      "description": "pip install (non-user)",
      "category": "package",
      "severity": "warn"
    },
    {
      "pattern": "\\bdocker\\s+rm\\b(?!.*-f)",
      "description": "docker remove container",
      "category": "docker",
      "severity": "warn"
    },
    {
      "pattern": "\\bdocker\\s+rmi\\b",
      "description": "docker remove image",
      "category": "docker",
      "severity": "warn"
    }
  ]
}
