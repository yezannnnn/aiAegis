{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.aegis/claude-hook.js",
            "timeout": 5
          }
        ],
        "description": "Aegis safety check for dangerous Bash commands"
      }
    ]
  }
}